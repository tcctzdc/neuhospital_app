@import '../../styles/variables.wxss';

.service-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  padding: 12rpx 0;
  box-sizing: border-box;
}

.service-item__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  flex-shrink: 0;
}

.service-item__emoji {
  font-size: 38rpx;
  line-height: 1;
}

.service-item__label {
  display: block;
  width: 100%;
  padding: 0 4rpx;
  font-size: 22rpx;
  color: #1f2937;
  text-align: center;
  line-height: 1.4;
  word-break: keep-all;
  white-space: normal;
  box-sizing: border-box;
}

.service-item__badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 15rpx;
  text-align: center;
  line-height: 30rpx;
  z-index: 1;
}
