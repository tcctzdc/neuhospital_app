@import './variables.wxss';

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

.page-padding {
  padding: 24rpx 32rpx;
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.card-body {
  padding: 28rpx 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title__text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.section-title__more {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.btn-primary {
  background: linear-gradient(135deg, #1677ff 0%, #13c2c2 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 48rpx;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 48rpx;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-outline::after {
  border: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-secondary);
}

.empty-state__icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-state__text {
  font-size: 28rpx;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
