.profile-header {
  position: relative;
  padding: 48rpx 32rpx 0;
  margin-bottom: 24rpx;
}

.profile-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(160deg, #1677ff 0%, #13c2c2 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-user {
  position: relative;
  display: flex;
  align-items: center;
  padding: 24rpx 0 40rpx;
}

.profile-user__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
  margin-right: 24rpx;
}

.profile-user__info {
  flex: 1;
}

.profile-user__name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.profile-user__phone {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.profile-user__arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

.profile-stats {
  position: relative;
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}

.profile-stat {
  flex: 1;
  text-align: center;
}

.profile-stat__num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.profile-stat__label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.profile-stat__divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border);
}

.profile-section__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  padding: 28rpx 32rpx 8rpx;
}

.profile-menu__item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.profile-menu__item:last-child {
  border-bottom: none;
}

.profile-menu__icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.profile-menu__label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.profile-menu__arrow {
  color: var(--color-text-placeholder);
  font-size: 36rpx;
}

.profile-logout {
  margin-top: 48rpx;
  width: 100%;
}
