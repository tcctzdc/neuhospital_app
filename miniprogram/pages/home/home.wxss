@import '../../styles/variables.wxss';

.home {
  min-height: 100vh;
  background-color: #f3f6fb;
  box-sizing: border-box;
}

/* 顶部渐变标题区 */
.home-header {
  background: linear-gradient(160deg, #1677ff 0%, #13c2c2 100%);
  padding: 20rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  text-align: center;
}

.home-header__title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.home-header__subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 8rpx;
  text-align: center;
}

/* 主体内容区：不用负 margin，避免元素叠在一起 */
.home-body {
  padding: 24rpx 32rpx 0;
  box-sizing: border-box;
}

/* 搜索框 */
.home-search {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 48rpx;
  padding: 22rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 255, 0.1);
}

.home-search__icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.home-search__text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 轮播 */
.home-banner {
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.home-banner__item {
  height: 100%;
  padding: 36rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.home-banner__item--0 {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
}

.home-banner__item--1 {
  background: linear-gradient(135deg, #597ef7, #1677ff);
}

.home-banner__item--2 {
  background: linear-gradient(135deg, #13c2c2, #08979c);
}

.home-banner__tag {
  display: inline-block;
  align-self: flex-start;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.home-banner__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.home-banner__desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(22, 119, 255, 0.08);
  overflow: hidden;
}

/* 快捷服务：4 列网格 */
.home-services {
  margin-bottom: 24rpx;
  overflow: visible;
}

.home-services__title {
  padding: 28rpx 32rpx 8rpx;
}

.home-services__title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.home-services__grid {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  width: 100%;
  padding: 8rpx 8rpx 28rpx;
  box-sizing: border-box;
}

.home-service-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  flex: 0 0 25%;
  max-width: 25%;
  padding: 12rpx 0;
  box-sizing: border-box;
}

.home-service-item__icon {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.home-service-item__emoji {
  font-size: 38rpx;
  line-height: 1;
}

.home-service-item__badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 15rpx;
  text-align: center;
  line-height: 30rpx;
}

.home-service-item__label {
  display: block;
  width: 100%;
  padding: 0 6rpx;
  font-size: 22rpx;
  color: #1f2937;
  text-align: center;
  line-height: 1.4;
  box-sizing: border-box;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title__text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-title__more {
  font-size: 24rpx;
  color: #6b7280;
}

.home-ai {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #e6f4ff 0%, #e6fffb 100%);
  border: 2rpx solid rgba(22, 119, 255, 0.12);
}

.home-ai__left {
  display: flex;
  align-items: center;
}

.home-ai__badge {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #1677ff, #13c2c2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.home-ai__title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.home-ai__desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.home-ai__arrow {
  font-size: 48rpx;
  color: #1677ff;
  font-weight: 300;
  flex-shrink: 0;
}

.home-section {
  margin-bottom: 32rpx;
}

.home-depts {
  width: 100%;
  white-space: nowrap;
}

.home-dept {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 148rpx;
  margin-right: 12rpx;
}

.home-dept__icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.home-dept__name {
  font-size: 24rpx;
  color: #1f2937;
  text-align: center;
  white-space: normal;
  line-height: 1.3;
}

.home-todo {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.home-todo:last-child {
  border-bottom: none;
}

.home-todo__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.home-todo__dot--warning { background: #faad14; }
.home-todo__dot--danger { background: #ff4d4f; }
.home-todo__dot--primary { background: #1677ff; }

.home-todo__content {
  flex: 1;
  min-width: 0;
}

.home-todo__title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

.home-todo__desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.home-todo__arrow {
  color: #9ca3af;
  font-size: 36rpx;
}

.home-bottom-space {
  height: 32rpx;
}
