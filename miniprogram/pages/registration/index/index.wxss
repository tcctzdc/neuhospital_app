.reg-steps {
  display: flex;
  padding: 32rpx 16rpx;
}

.reg-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
}

.reg-step:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 28rpx;
  right: -20%;
  width: 40%;
  height: 2rpx;
  background: var(--color-border);
}

.reg-step__num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff, #13c2c2);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.reg-step__title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reg-step__desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.reg-action {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.reg-action:last-child {
  border-bottom: none;
}

.reg-action__icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.reg-action__info {
  flex: 1;
}

.reg-action__title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reg-action__desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.reg-action__arrow {
  font-size: 40rpx;
  color: var(--color-text-placeholder);
}
