<view class="page page-padding page-shell">
  <view wx:if="{{loading}}" class="page-overlay">
    <view class="page-loading">
      <view class="page-loading__ring"></view>
      <text class="page-loading__text">加载中...</text>
    </view>
  </view>

  <view hidden="{{loading}}">
  <!-- 步骤引导 -->
  <view class="reg-steps card">
    <view class="reg-step" wx:for="{{steps}}" wx:key="title">
      <view class="reg-step__num">{{index + 1}}</view>
      <text class="reg-step__title">{{item.title}}</text>
      <text class="reg-step__desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="card" style="margin-top: 24rpx">
    <view class="reg-action" bindtap="goDepartment">
      <view class="reg-action__icon">🏥</view>
      <view class="reg-action__info">
        <text class="reg-action__title">按科室挂号</text>
        <text class="reg-action__desc">选择科室 → 选择医生 → 选择时段</text>
      </view>
      <text class="reg-action__arrow">›</text>
    </view>
    <view class="reg-action" bindtap="goMyList">
      <view class="reg-action__icon">📋</view>
      <view class="reg-action__info">
        <text class="reg-action__title">我的挂号</text>
        <text class="reg-action__desc">查看预约记录、退号</text>
      </view>
      <text class="reg-action__arrow">›</text>
    </view>
  </view>

  <!-- 今日可约 -->
  <view class="section-title" style="margin-top: 32rpx">
    <text class="section-title__text">今日可约</text>
    <text class="section-title__more">{{today}}</text>
  </view>

  <doctor-card
    wx:for="{{todayDoctors}}"
    wx:key="id"
    id="{{item.id}}"
    name="{{item.name}}"
    title="{{item.title}}"
    department="{{item.department}}"
    specialty="{{item.specialty}}"
    status-text="{{item.statusText}}"
    status-type="{{item.statusType}}"
    fee="{{item.fee}}"
    avatar-text="{{item.avatarText}}"
    bind:tap="goDoctor"
    data-id="{{item.id}}"
  />

  <view wx:if="{{!todayDoctors.length}}" class="empty-state card">
    <text class="empty-state__icon">😔</text>
    <text class="empty-state__text">今日暂无可约医生</text>
  </view>
  </view>
</view>
