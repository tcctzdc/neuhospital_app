.tabs {
  display: flex;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tabs__item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
}

.tabs__item--active {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: 600;
}

.reg-item {
  margin-bottom: 20rpx;
  padding: 28rpx 32rpx;
}

.reg-item__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.reg-item__no {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.reg-item__dept {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reg-item__time {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.reg-item__queue {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
}

.reg-item__footer {
  margin-top: 20rpx;
  text-align: right;
}

.reg-item__btn {
  display: inline-block;
  width: auto;
  padding: 0 40rpx;
  font-size: 24rpx;
}
