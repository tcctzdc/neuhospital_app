.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1677ff 0%, #f3f6fb 40%);
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 64rpx;
}

.login-header__logo {
  font-size: 96rpx;
  display: block;
  margin-bottom: 16rpx;
}

.login-header__title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.login-header__desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.login-form {
  padding: 48rpx 40rpx;
}

.login-field {
  margin-bottom: 32rpx;
}

.login-field__label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.login-field__input {
  height: 88rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 30rpx;
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
}

.login-footer {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.login-footer__link {
  color: var(--color-primary);
  margin-left: 8rpx;
}
