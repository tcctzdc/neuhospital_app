.medical-header {
  padding: 32rpx;
  text-align: center;
}

.medical-header__title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}

.medical-header__meta {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.medical-section {
  padding: 28rpx 32rpx;
}

.medical-section__label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.medical-section__content {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.7;
}

.medical-diagnosis {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.medical-diagnosis:last-child {
  border-bottom: none;
}

.medical-diagnosis__name {
  font-size: 28rpx;
  color: var(--color-text);
}

.medical-diagnosis__code {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
