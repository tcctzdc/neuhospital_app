.tabs {
  display: flex;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.tabs__item {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
}

.tabs__item--active {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: 600;
}

.record-item {
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.record-item__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.record-item__title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.record-item__dept {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.record-item__time {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}
